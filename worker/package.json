{
  "name": "downloadanything-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "sync-shared": "cp ../shared/types.ts src/shared-types.ts && cp ../shared/errors.ts src/shared-errors.ts",
    "predev": "npm run sync-shared",
    "prebuild": "npm run sync-shared",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@hono/node-server": "^1.13.7",
    "archiver": "^7.0.1",
    "hono": "^4.6.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
